# ── Base de datos ──
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/zyra

# ── Auth ──
JWT_SECRET=cambia_esto_por_algo_largo_y_aleatorio

# ── IA ──
GROQ_API_KEY=gsk_...
# PYTHON_SERVICE=http://localhost:5000   # Opcional: servicio Python para análisis de emociones

# ── Música (YouTube Data API v3) ──
YT_API_KEY=AIza...

# ── Pagos (Stripe) ──
STRIPE_SECRET_KEY=sk_live_...          # o sk_test_... para pruebas
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC_M=price_...        # Price ID plan Básico mensual
STRIPE_PRICE_BASIC_Y=price_...        # Price ID plan Básico anual
STRIPE_PRICE_PREMIUM_M=price_...      # Price ID plan Premium mensual
STRIPE_PRICE_PREMIUM_Y=price_...      # Price ID plan Premium anual

# ── Push Notifications (Web Push / VAPID) ──
# Generar con: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=BN...
VAPID_PRIVATE_KEY=...
VAPID_EMAIL=mailto:soporte@zyra.app

# ── Email (Brevo / Sendinblue) ──
EMAIL_USER=tu@gmail.com               # Dirección de remitente en Brevo
BREVO_API_KEY=xkeysib-...             # API key de Brevo (antes Sendinblue)

# ── App ──
NODE_ENV=production
APP_URL=https://tu-app.onrender.com
ALLOWED_ORIGINS=https://tu-app.onrender.com
ADMIN_EMAIL=admin@tudominio.com
PORT=438

# ── Monitoreo de errores ──
# Crear cuenta gratis en sentry.io → New Project → Node.js → copiar DSN
SENTRY_DSN=https://...@sentry.io/...
